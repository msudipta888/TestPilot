generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  username      String?
  email         String?        @unique
  password      String?
  emailVerified Boolean        @default(false)
  accessToken   String?        @unique
  repos         reposInfo[]
  selectedRepo  selectedRepo[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model reposInfo {
  id        String   @id @default(cuid())
  reposName String   @unique
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model selectedRepo {
  id            String           @id @default(cuid())
  githubRepoId  Int              @unique
  repoName      String           @unique
  repoUrl       String
  defaultBranch String           @default("main")
  isPrivate     Boolean          @default(false)
  userId        String
  generatedTest generatedTests[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User             @relation(fields: [userId], references: [id])
}

model generatedTests {
  id                String       @id @default(cuid())
  userId            String
  repoId            String
  title             String
  repoName          String       @unique
  repoOwner         String       @unique
  branch            String
  description       String
  type              String
  priority          String
  targetRoute       String
  targetFiles       String[]
  expectedResult    String
  browserbaseScript String
  status            String       @default("generated")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  repo              selectedRepo @relation(fields: [repoId], references: [id])
}
